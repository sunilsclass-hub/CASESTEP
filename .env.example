# CaseStep — optional Supabase backend
#
# The platform works fully WITHOUT these variables (progress is stored locally
# in the browser). Set them to enable cloud accounts and multi-device sync.
#
# 1. Create a free project at https://supabase.com
# 2. Project Settings → API → copy the Project URL and the anon/public key
# 3. Copy this file to `.env.local` and fill in the values
# 4. Run the SQL in `supabase/schema.sql` in the Supabase SQL editor
#
# These are PUBLIC (browser-exposed) values — the anon key is safe to ship;
# row-level security in schema.sql protects the data. NEVER put the service_role
# key here.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
